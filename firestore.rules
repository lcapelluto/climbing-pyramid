rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write the single document that holds
    // their own climbs and pyramid config: /users/{their-own-uid}
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
